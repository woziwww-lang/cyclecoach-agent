DATABASE_URL="file:./dev.db"

APP_URL="http://localhost:3000"
SESSION_COOKIE_NAME="cc_user_id"

STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""
STRAVA_REDIRECT_URI="http://localhost:3000/api/auth/strava/callback"

OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:7b"

# Optional route intelligence. The app runs without these and falls back to
# previous Strava activities plus the built-in Tokyo/Kanto route catalog.
ORS_API_KEY=""
ROUTE_PROVIDER="openrouteservice"
ENABLE_EXTERNAL_ROUTE_SEARCH="true"
ENABLE_RIDER_PROFILE="true"
ENABLE_CHARTS="true"
