{
  "name": "cyclecoach-agent",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "build": "prisma generate && next build",
    "start": "next start",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome lint .",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "playwright:install": "playwright install --with-deps chromium",
    "quality:unused": "knip --no-config-hints",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "ollama:up": "docker compose up -d ollama",
    "ollama:down": "docker compose stop ollama",
    "ollama:pull": "node scripts/ollama-pull.mjs",
    "ollama:pull:3b": "OLLAMA_MODEL=qwen2.5:3b node scripts/ollama-pull.mjs",
    "ollama:pull:7b": "OLLAMA_MODEL=qwen2.5:7b node scripts/ollama-pull.mjs",
    "ollama:pull:tiny": "OLLAMA_MODEL=qwen2.5:0.5b node scripts/ollama-pull.mjs",
    "ollama:list": "docker compose exec ollama ollama list",
    "ollama:smoke": "node scripts/ollama-smoke.mjs",
    "ollama:logs": "docker compose logs -f ollama",
    "app:health": "node scripts/app-health.mjs",
    "local:setup": "pnpm db:push && pnpm db:seed && pnpm ollama:up && pnpm ollama:pull",
    "dev:local": "pnpm ollama:up && pnpm dev"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@tanstack/react-query": "^5.62.7",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "next": "^15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.13.3",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@biomejs/biome": "2.4.16",
    "@playwright/test": "1.60.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/leaflet": "^1.9.14",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.0.3",
    "jsdom": "29.1.1",
    "knip": "6.14.2",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
