{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "next.config.ts",
    "tailwind.config.ts",
    "postcss.config.mjs",
    "vitest.config.ts",
    "playwright.config.ts",
    "app/**/{page,layout,loading,error,not-found,route}.ts",
    "app/**/{page,layout,loading,error,not-found,route}.tsx",
    "scripts/*.mjs",
    "prisma/seed.ts",
    "tests/**/*.test.ts",
    "tests/**/*.test.tsx",
    "tests/e2e/**/*.spec.ts"
  ],
  "project": [
    "**/*.{ts,tsx,mjs,cjs,js,jsx}",
    "!node_modules/**",
    "!.next/**",
    "!coverage/**",
    "!playwright-report/**",
    "!test-results/**"
  ],
  "ignore": [
    "next-env.d.ts",
    ".next/**",
    "components.json"
  ],
  "ignoreDependencies": [
    "eslint",
    "eslint-config-next"
  ]
}
